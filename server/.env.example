# Connection string PostgreSQL dari Supabase
# Format: postgresql://postgres.[project-ref]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres
DATABASE_URL=postgresql://postgres.xxxx:password@aws-0-ap-southeast-1.pooler.supabase.com:6543/postgres

# Secret untuk session (buat string random, minimal 32 karakter)
SESSION_SECRET=ganti-dengan-string-random-yang-panjang

# URL frontend (domain Vercel)
# Development: http://localhost:5173
# Production: https://nama-project-kamu.vercel.app
CLIENT_URL=http://localhost:5173

# URL backend sendiri (domain Render)
# Development: http://localhost:5000
# Production: https://nama-backend-kamu.onrender.com
SERVER_URL=http://localhost:5000

# Port server (Render otomatis set PORT)
PORT=5000

# Environment
NODE_ENV=production
